# Exclude everything by default
*

# Allow directories
!*/

# Explicitly ignore dependency and build folders (stops recursive allow-list matching)
node_modules/
dist/
out/
.eslintcache
.vscode/
site/node_modules/
site/dist/

# Allow configuration files
!.gitignore
!.npmrc
!package.json
!tsconfig.json
!tsconfig.node.json
!tsconfig.web.json
!electron.vite.config.ts
!electron-builder.yml
!eslint.config.mjs
!.editorconfig
!.prettierignore
!.prettierrc.yaml

# Allow source files
!src/**
!core/**
core/multimux-core.exe
core/multimux-core
core/multimux-core.pdb

# Allow resources & build configurations
!resources/**
!build/**

# Allow workflows
!.github/**

# Allow documentation & website
!README.adoc
!CHANGELOG.adoc
!changelog-details/**
!docs/**
!site/package.json
!site/build.js
